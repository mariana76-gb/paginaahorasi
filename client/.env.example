# Netlify environment variables for the Frapessaurio contact function
# Copia los valores y pega aquí los datos de tu sitio Netlify.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Frapessaurio Backend <no-reply@example.com>"
CONTACT_TO=contact@example.com

# No external API backend is required when using Netlify Functions.
# Leave frontend API URL configuration empty for Netlify-hosted deployment.
